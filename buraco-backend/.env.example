# App
NODE_ENV=development
PORT=3000
APP_URL=http://localhost:3000

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/buraco_db

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=change-me-to-a-long-random-secret
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change-me-to-another-long-random-secret
JWT_REFRESH_EXPIRES_IN=30d

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Apple Sign-In
APPLE_CLIENT_ID=
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY=

# AWS S3
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=buraco-game-assets

# Email (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@buraco.game

# Admin
ADMIN_JWT_SECRET=change-me-admin-secret
ADMIN_JWT_EXPIRES_IN=8h

# Rate Limiting
THROTTLE_TTL=60
THROTTLE_LIMIT=100

# Game Config
DISCONNECT_TIMEOUT_SECONDS=60
DEFAULT_TURN_DURATION=30
NEW_USER_COINS=1000
NEW_USER_DIAMONDS=0
NEW_USER_LIVES=5
